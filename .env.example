# ──────────────────────────────────────────────
# ECO — Plataforma SaaS Multi-tenant de Ventas con IA
# ──────────────────────────────────────────────

# SERVER
ENVIRONMENT=development
DEBUG=true
PORT=8000

# Clave secreta JWT (cambiar en producción)
SECRET_KEY=change_me_to_a_random_secret

# ── BASE DE DATOS ─────────────────────────────
DATABASE_URL=postgresql+asyncpg://eco:eco_secret@postgres:5432/eco_db
DB_PASSWORD=eco_secret

# ── REDIS (Celery broker) ─────────────────────
REDIS_URL=redis://redis:6379/0

# ── GEMINI API (IA + Embeddings) ──────────────
# El modelo de chat y embeddings se configuran aquí como fallback global.
# Cada workspace puede sobrescribir openai_api_key desde el Dashboard (/settings).
OPENAI_API_KEY=tu_api_key_de_gemini
OPENAI_MODEL=gemini-2.5-flash
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# ── TELEGRAM ──────────────────────────────────
# Fallback global. Se puede configurar por workspace desde el Dashboard.
TELEGRAM_BOT_TOKEN=

# ── WHATSAPP (Meta Cloud API) ────────────────
# Fallback global. Se puede configurar por workspace desde el Dashboard.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_BASE_URL=https://graph.facebook.com

# ── MOCK WHATSAPP (desarrollo) ────────────────
MOCK_WHATSAPP_URL=http://mock-whatsapp:4010
