# ══════════════════════════════════════════════════════════
#  ECO — Produccion (Template)
#  Copiar a .env.production y completar con valores reales.
#  JAMAS commitear .env.production con secretos reales.
# ══════════════════════════════════════════════════════════

# ── APP ───────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=False
PORT=8000

# Generar con:  openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_RANDOM_HEX_64_CHARS

# Nivel de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Origenes permitidos por CORS (separados por coma)
CORS_ORIGINS=https://midominio.com

# URL del frontend (para redirecciones OAuth / webhooks)
FRONTEND_URL=https://midominio.com


# ── BASE DE DATOS (PostgreSQL + pgvector) ─────────────────
POSTGRES_DB=eco_db
POSTGRES_USER=eco
POSTGRES_PASSWORD=YOUR_DB_PASSWORD

# Connection string asincrono para SQLAlchemy + asyncpg
DATABASE_URL=postgresql+asyncpg://eco:YOUR_DB_PASSWORD@postgres:5432/eco_db


# ── REDIS & CELERY ───────────────────────────────────────
REDIS_URL=redis://YOUR_REDIS_HOST:6379/0


# ── OPENAI / GEMINI (IA) ─────────────────────────────────
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gemini-2.5-flash
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/


# ── TELEGRAM ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN


# ── WHATSAPP (Meta Cloud API) ────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID
WHATSAPP_ACCESS_TOKEN=YOUR_ACCESS_TOKEN
WHATSAPP_VERIFY_TOKEN=YOUR_VERIFY_TOKEN
WHATSAPP_API_VERSION=v21.0
WHATSAPP_BASE_URL=https://graph.facebook.com


# ── STRIPE (Suscripciones) ──────────────────────────────
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET
STRIPE_PRO_PRICE_ID=YOUR_STRIPE_PRO_PRICE_ID
STRIPE_ENTERPRISE_PRICE_ID=YOUR_STRIPE_ENTERPRISE_PRICE_ID


# ── FRONTEND (Build-time) ────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.midominio.com/api/v1
NEXT_PUBLIC_WS_URL=wss://api.midominio.com/api/v1/conversations/ws
