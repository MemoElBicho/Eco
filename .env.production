# ══════════════════════════════════════════════════════════
#  ECO — Produccion
#  Copia este archivo como .env.production y completa los valores.
# ══════════════════════════════════════════════════════════

# ── APP ───────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=False
PORT=8000

# Generar con:  openssl rand -hex 32
# JAMAS usar el valor por defecto en produccion.
SECRET_KEY=change_me_to_a_random_secret

# Nivel de log: DEBUG | INFO | WARNING | ERROR
# En produccion se fuerza a INFO si se deja en DEBUG.
LOG_LEVEL=INFO

# Origenes permitidos por CORS (separados por coma)
# NO usar "*" en produccion — el backend lo rechaza.
CORS_ORIGINS=https://midominio.com,https://admin.midominio.com

# URL del frontend (para redirecciones OAuth / webhooks)
FRONTEND_URL=https://midominio.com


# ── BASE DE DATOS (PostgreSQL + pgvector) ─────────────────
POSTGRES_DB=eco_db
POSTGRES_USER=eco
POSTGRES_PASSWORD=eco_secret

# Connection string asincrono para SQLAlchemy + asyncpg
DATABASE_URL=postgresql+asyncpg://eco:eco_secret@postgres:5432/eco_db
DB_PASSWORD=eco_secret


# ── REDIS & CELERY ───────────────────────────────────────
REDIS_URL=redis://redis:6379/0


# ── OPENAI / GEMINI (IA) ─────────────────────────────────
# Modelo de chat y embeddings. Cada workspace puede sobrescribirlo
# desde el Dashboard (/settings).
OPENAI_API_KEY=sk-placeholder
OPENAI_MODEL=gemini-2.5-flash
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/


# ── TELEGRAM ─────────────────────────────────────────────
# Fallback global. Se puede configurar por workspace.
TELEGRAM_BOT_TOKEN=


# ── WHATSAPP (Meta Cloud API) ────────────────────────────
# Fallback global. Se puede configurar por workspace.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_BASE_URL=https://graph.facebook.com


# ── STRIPE (Suscripciones) ──────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=


# ── FRONTEND (Build-time) ────────────────────────────────
# Se pasan como --build-arg al Dockerfile multi-stage.
# Deben coincidir con el dominio publico del backend.

NEXT_PUBLIC_API_URL=https://api.midominio.com/api/v1
NEXT_PUBLIC_WS_URL=wss://api.midominio.com/api/v1/conversations/ws
